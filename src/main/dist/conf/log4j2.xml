<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_ERR">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c - %msg%n"/>
        </Console>
    </Appenders>

    <!-- Loggers -->
    <Loggers>
        <!-- Package-level logger for collector components at DEBUG -->
        <Logger name="io.coherity.estoria.collector" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Default root logger at INFO level -->
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
